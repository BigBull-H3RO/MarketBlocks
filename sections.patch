+            y += 20;
+
+            host.addSettingsWidget(new FloatSlider(leftX, y, 80, 16, Component.translatable("gui.marketblocks.visuals.height"), -0.5f, 1.5f, draftOfferItemHeightOffset, onHeightChanged));
+            host.addSettingsWidget(Checkbox.builder(
